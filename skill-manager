#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

die()  { echo -e "${RED}error: $1${RESET}" >&2; exit 1; }
ok()   { echo -e "  ${GREEN}✓${RESET} $1"; }
warn() { echo -e "  ${YELLOW}⚠${RESET} $1"; }
err()  { echo -e "  ${RED}✗${RESET} $1"; }

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SELF_DIR/claude-defaults.sh"
source "$SELF_DIR/claude-schema.sh"

CONF_FILE=".claude/.skill-manager.conf"
MANIFEST_FILE=".claude/.skill-manifest"
GLOBAL_CONF_FILE="$HOME/.skill-manager.conf"

# ---------------------------------------------------------------------------
# Per-repo config
# ---------------------------------------------------------------------------

load_config() {
  SKILLS_DIR=""
  if [[ -f "$CONF_FILE" ]]; then source "$CONF_FILE"; fi
}

save_config() {
  mkdir -p ".claude"
  cat > "$CONF_FILE" <<EOF
SKILLS_DIR="$SKILLS_DIR"
EOF
  ok "config saved → $CONF_FILE"
}

ensure_config() {
  load_config
  if [[ -z "$SKILLS_DIR" ]]; then
    echo -e "\n${BOLD}First time setup for this repo${RESET}"
    echo -e "${CYAN}Skills directory (relative path from repo root):${RESET} "
    read -r input
    [[ -n "$input" ]] || die "path cannot be empty"
    SKILLS_DIR="${input%/}"
    save_config
    echo ""
  fi
}

check_skills_dir() {
  [[ -d "$SKILLS_DIR" ]] || die "skills directory not found: '$SKILLS_DIR'\n       run from repo root or reset with: skill-manager config reset"
}

# ---------------------------------------------------------------------------
# Global config
# ---------------------------------------------------------------------------

load_global_config() {
  GLOBAL_SKILLS_DIR=""
  if [[ -f "$GLOBAL_CONF_FILE" ]]; then source "$GLOBAL_CONF_FILE"; fi
}

save_global_config() {
  cat > "$GLOBAL_CONF_FILE" <<EOF
GLOBAL_SKILLS_DIR="$GLOBAL_SKILLS_DIR"
EOF
  ok "global config saved → $GLOBAL_CONF_FILE"
}

# ---------------------------------------------------------------------------
# Skill helpers
# ---------------------------------------------------------------------------

get_field() {
  local file="$1" field="$2"
  awk -v f="$field" '
    BEGIN { depth=0 }
    /^---/ { depth++; next }
    depth==1 && $0 ~ "^"f":" {
      sub("^"f":[[:space:]]*",""); gsub(/^["'"'"']|["'"'"']$/,""); print; exit
    }
    depth>=2 { exit }
  ' "$file"
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

VALIDATION_ERRORS=()
VALIDATION_WARNINGS=()

validate_skill() {
  local name="$1" dir="$2"
  local md="$dir/SKILL.md"
  VALIDATION_ERRORS=()
  VALIDATION_WARNINGS=()

  local fence_count
  fence_count=$(awk '/^---/{c++} END{print c+0}' "$md")
  if [[ $fence_count -lt 2 ]]; then
    VALIDATION_ERRORS+=("missing frontmatter delimiters (---)")
  fi

  local name_val
  name_val=$(get_field "$md" "name")
  if [[ -n "$name_val" ]] && ! echo "$name_val" | grep -qE "$SCHEMA_NAME_REGEX"; then
    VALIDATION_ERRORS+=("invalid name '$name_val' — must match: $SCHEMA_NAME_REGEX")
  fi

  local effort_val
  effort_val=$(get_field "$md" "effort")
  if [[ -n "$effort_val" ]] && ! echo " $SCHEMA_EFFORT_ALLOWED " | grep -qw "$effort_val"; then
    VALIDATION_ERRORS+=("invalid effort '$effort_val' — must be one of: $SCHEMA_EFFORT_ALLOWED")
  fi

  local context_val
  context_val=$(get_field "$md" "context")
  if [[ -n "$context_val" ]] && ! echo " $SCHEMA_CONTEXT_ALLOWED " | grep -qw "$context_val"; then
    VALIDATION_ERRORS+=("invalid context '$context_val' — must be one of: $SCHEMA_CONTEXT_ALLOWED")
  fi

  local desc_val
  desc_val=$(get_field "$md" "description")
  if [[ -z "$desc_val" ]]; then
    VALIDATION_WARNINGS+=("no description field (recommended for skill discovery)")
  fi

  [[ ${#VALIDATION_ERRORS[@]} -eq 0 ]]
}

# ---------------------------------------------------------------------------
# Build combined skill list from repo + global sources
# ---------------------------------------------------------------------------

SKILL_NAMES=()
SKILL_DIRS=()
SKILL_DESCS=()
SKILL_STATUS=()
SKILL_ISSUES=()
SKILL_SOURCE=()

append_skills_from() {
  local skills_dir="$1" source_label="$2"

  for dir in "$skills_dir"/*/; do
    if [[ ! -d "$dir" ]]; then continue; fi
    local md="$dir/SKILL.md"
    if [[ ! -f "$md" ]]; then continue; fi

    local name desc
    name=$(basename "$dir")
    desc=$(get_field "$md" "description")
    desc="${desc:0:65}"

    local status issue
    if validate_skill "$name" "$dir"; then
      if [[ ${#VALIDATION_WARNINGS[@]} -gt 0 ]]; then
        status="warn"; issue="${VALIDATION_WARNINGS[0]}"
      else
        status="ok"; issue=""
      fi
    else
      status="error"; issue="${VALIDATION_ERRORS[0]}"; desc="—"
    fi

    SKILL_NAMES+=("$name")
    SKILL_DIRS+=("$dir")
    SKILL_DESCS+=("$desc")
    SKILL_STATUS+=("$status")
    SKILL_ISSUES+=("$issue")
    SKILL_SOURCE+=("$source_label")
  done
}

build_skill_list() {
  SKILL_NAMES=(); SKILL_DIRS=(); SKILL_DESCS=()
  SKILL_STATUS=(); SKILL_ISSUES=(); SKILL_SOURCE=()

  if [[ -n "$SKILLS_DIR" && -d "$SKILLS_DIR" ]]; then
    append_skills_from "$SKILLS_DIR" "repo"
  fi

  load_global_config
  if [[ -n "$GLOBAL_SKILLS_DIR" && -d "$GLOBAL_SKILLS_DIR" ]]; then
    append_skills_from "$GLOBAL_SKILLS_DIR" "global"
  fi
}

is_active() {
  local name="$1"
  if [[ -f "$MANIFEST_FILE" ]] && grep -qx "$name" "$MANIFEST_FILE" 2>/dev/null; then
    return 0
  fi
  return 1
}

# ---------------------------------------------------------------------------
# Print a section header when source changes
# ---------------------------------------------------------------------------

print_section_header() {
  local source="$1"
  if [[ "$source" == "repo" ]]; then
    printf "\n${BOLD}── ${CYAN}repo${RESET}${BOLD}: ${DIM}%s${RESET}\n\n" "$SKILLS_DIR"
  else
    printf "\n${BOLD}── ${BLUE}global${RESET}${BOLD}: ${DIM}%s${RESET}\n\n" "$GLOBAL_SKILLS_DIR"
  fi
}

# Print a skill row (using original index in SKILL_NAMES)
print_skill_row() {
  local display_num="$1" skill_idx="$2"
  local name="${SKILL_NAMES[$skill_idx]}"
  local status="${SKILL_STATUS[$skill_idx]}"

  local prefix
  if [[ "$status" == "error" ]]; then
    prefix="${RED} ✗ ${RESET}"
  elif is_active "$name"; then
    prefix="${GREEN} ✓ ${RESET}"
  elif [[ "$status" == "warn" ]]; then
    prefix="${YELLOW} ⚠ ${RESET}"
  else
    prefix="   "
  fi

  printf "  ${prefix}${CYAN}[%2d]${RESET} %-36s %s\n" \
    "$display_num" "$name" "${SKILL_DESCS[$skill_idx]}"
  if [[ -n "${SKILL_ISSUES[$skill_idx]}" ]]; then
    printf "            ${YELLOW}%s${RESET}\n" "${SKILL_ISSUES[$skill_idx]}"
  fi
}

# ---------------------------------------------------------------------------
# Parse selection string into SELECTED_INDICES using global DISPLAY_MAP
# DISPLAY_MAP maps display numbers (1-based) to SKILL_NAMES indices
# ---------------------------------------------------------------------------

DISPLAY_MAP=()
SELECTED_INDICES=()

parse_selection() {
  local selection="$1"
  SELECTED_INDICES=()

  if [[ "$selection" == "all" ]]; then
    for i in "${!DISPLAY_MAP[@]}"; do SELECTED_INDICES+=($i); done
    return
  fi
  for token in $selection; do
    if [[ "$token" =~ ^([0-9]+)-([0-9]+)$ ]]; then
      for ((j=${BASH_REMATCH[1]}; j<=${BASH_REMATCH[2]}; j++)); do
        SELECTED_INDICES+=($((j-1)))
      done
    elif [[ "$token" =~ ^[0-9]+$ ]]; then
      SELECTED_INDICES+=($((token-1)))
    fi
  done
}

# ---------------------------------------------------------------------------
# Install / remove
# ---------------------------------------------------------------------------

install_skill() {
  local name="$1" src_dir="$2"
  local dest="$CLAUDE_SKILLS_DIR/$name"
  mkdir -p "$CLAUDE_SKILLS_DIR"
  rm -rf "$dest"
  cp -r "$src_dir" "$dest"
  if ! grep -qx "$name" "$MANIFEST_FILE" 2>/dev/null; then
    echo "$name" >> "$MANIFEST_FILE"
  fi
  ok "$name → $dest/"
}

remove_skill() {
  local name="$1"
  local dest="$CLAUDE_SKILLS_DIR/$name"
  if [[ -d "$dest" ]]; then rm -rf "$dest"; return 0; fi
  return 1
}

# ---------------------------------------------------------------------------
# cmd: start — clear previous session + full menu + install selected
# ---------------------------------------------------------------------------

cmd_start() {
  ensure_config
  check_skills_dir
  build_skill_list

  [[ ${#SKILL_NAMES[@]} -gt 0 ]] || die "no skills found"

  # Clear previous session
  if [[ -f "$MANIFEST_FILE" && -s "$MANIFEST_FILE" ]]; then
    local removed=0
    while IFS= read -r name; do
      if [[ -z "$name" ]]; then continue; fi
      if remove_skill "$name"; then removed=$((removed + 1)); fi
    done < "$MANIFEST_FILE"
    rm "$MANIFEST_FILE"
    if [[ $removed -gt 0 ]]; then
      echo -e "  ${YELLOW}↺${RESET} cleared $removed skill(s) from previous session\n"
    fi
  fi

  # Print full menu
  echo -e "\n${BOLD}Available skills (${#SKILL_NAMES[@]}):${RESET}"
  local current_source="" num=1
  DISPLAY_MAP=()
  for i in "${!SKILL_NAMES[@]}"; do
    if [[ "${SKILL_SOURCE[$i]}" != "$current_source" ]]; then
      current_source="${SKILL_SOURCE[$i]}"
      print_section_header "$current_source"
    fi
    print_skill_row $num $i
    DISPLAY_MAP+=($i)
    num=$((num + 1))
  done

  echo -e "\n${YELLOW}Select (e.g: 1 3 5  |  1-4  |  all):${RESET} "
  read -r selection
  if [[ -z "$selection" ]]; then echo "Nothing selected."; exit 0; fi

  parse_selection "$selection"

  mkdir -p "$CLAUDE_SKILLS_DIR"
  touch "$MANIFEST_FILE"

  local count=0 skipped=0
  echo ""
  for di in "${SELECTED_INDICES[@]}"; do
    if [[ $di -lt 0 || $di -ge ${#DISPLAY_MAP[@]} ]]; then
      warn "index $((di+1)) out of range — skipped"; continue
    fi
    local idx="${DISPLAY_MAP[$di]}"
    local name="${SKILL_NAMES[$idx]}"
    if [[ "${SKILL_STATUS[$idx]}" == "error" ]]; then
      err "$name — skipped: ${SKILL_ISSUES[$idx]}"
      skipped=$((skipped + 1)); continue
    fi
    install_skill "$name" "${SKILL_DIRS[$idx]}"
    count=$((count + 1))
  done

  echo ""
  if [[ $count -gt 0 ]]; then
    echo -e "${GREEN}${BOLD}$count skill(s) activated.${RESET} Use them as ${BOLD}/<name>${RESET} in Claude Code."
  fi
  if [[ $skipped -gt 0 ]]; then
    echo -e "${RED}$skipped skill(s) skipped due to validation errors.${RESET}"
  fi
  echo ""
}

# ---------------------------------------------------------------------------
# cmd: resume — show active skills + offer to add more (no cleanup)
# ---------------------------------------------------------------------------

cmd_resume() {
  ensure_config
  check_skills_dir
  build_skill_list

  # Must have active skills to resume
  if [[ ! -f "$MANIFEST_FILE" || ! -s "$MANIFEST_FILE" ]]; then
    echo -e "\n${YELLOW}No active skills. Run 'skill-manager start' to begin a session.${RESET}\n"
    exit 0
  fi

  # Show currently active skills
  echo -e "\n${BOLD}Active skills:${RESET}\n"
  while IFS= read -r name; do
    if [[ -n "$name" ]]; then ok "$name  →  /$name"; fi
  done < "$MANIFEST_FILE"

  # Build list of non-active skills only
  local inactive_indices=()
  for i in "${!SKILL_NAMES[@]}"; do
    if ! is_active "${SKILL_NAMES[$i]}"; then
      inactive_indices+=($i)
    fi
  done

  if [[ ${#inactive_indices[@]} -eq 0 ]]; then
    echo -e "\n${GREEN}All available skills are already active.${RESET}\n"
    exit 0
  fi

  # Print non-active skills grouped by source
  echo -e "\n${BOLD}Available to add:${RESET}"
  local current_source="" num=1
  DISPLAY_MAP=()
  for idx in "${inactive_indices[@]}"; do
    if [[ "${SKILL_SOURCE[$idx]}" != "$current_source" ]]; then
      current_source="${SKILL_SOURCE[$idx]}"
      print_section_header "$current_source"
    fi
    print_skill_row $num $idx
    DISPLAY_MAP+=($idx)
    num=$((num + 1))
  done

  echo -e "\n${YELLOW}Select skills to add (or Enter to keep current):${RESET} "
  read -r selection
  if [[ -z "$selection" ]]; then echo "No changes."; exit 0; fi

  parse_selection "$selection"

  touch "$MANIFEST_FILE"

  local count=0 skipped=0
  echo ""
  for di in "${SELECTED_INDICES[@]}"; do
    if [[ $di -lt 0 || $di -ge ${#DISPLAY_MAP[@]} ]]; then
      warn "index $((di+1)) out of range — skipped"; continue
    fi
    local idx="${DISPLAY_MAP[$di]}"
    local name="${SKILL_NAMES[$idx]}"
    if [[ "${SKILL_STATUS[$idx]}" == "error" ]]; then
      err "$name — skipped: ${SKILL_ISSUES[$idx]}"
      skipped=$((skipped + 1)); continue
    fi
    install_skill "$name" "${SKILL_DIRS[$idx]}"
    count=$((count + 1))
  done

  echo ""
  if [[ $count -gt 0 ]]; then
    echo -e "${GREEN}${BOLD}$count skill(s) added.${RESET} Use them as ${BOLD}/<name>${RESET} in Claude Code."
  fi
  if [[ $skipped -gt 0 ]]; then
    echo -e "${RED}$skipped skill(s) skipped due to validation errors.${RESET}"
  fi
  echo ""
}

# ---------------------------------------------------------------------------
# cmd: stop — remove all active skills
# ---------------------------------------------------------------------------

cmd_stop() {
  load_config
  if [[ ! -f "$MANIFEST_FILE" || ! -s "$MANIFEST_FILE" ]]; then
    echo -e "\nNo active skills to remove.\n"
    return
  fi

  local count=0
  echo ""
  while IFS= read -r name; do
    if [[ -z "$name" ]]; then continue; fi
    if remove_skill "$name"; then
      echo -e "  ${RED}✗${RESET} removed $CLAUDE_SKILLS_DIR/$name/"
      count=$((count + 1))
    fi
  done < "$MANIFEST_FILE"

  rm "$MANIFEST_FILE"
  echo -e "\n${GREEN}$count skill(s) removed.${RESET}\n"
}

# ---------------------------------------------------------------------------
# cmd: list / active / config
# ---------------------------------------------------------------------------

cmd_list() {
  ensure_config
  check_skills_dir
  build_skill_list

  echo -e "\n${BOLD}Available skills (${#SKILL_NAMES[@]}):${RESET}"
  local current_source="" num=1
  for i in "${!SKILL_NAMES[@]}"; do
    if [[ "${SKILL_SOURCE[$i]}" != "$current_source" ]]; then
      current_source="${SKILL_SOURCE[$i]}"
      print_section_header "$current_source"
    fi
    print_skill_row $num $i
    num=$((num + 1))
  done
  echo ""
}

cmd_active() {
  load_config
  if [[ ! -f "$MANIFEST_FILE" || ! -s "$MANIFEST_FILE" ]]; then
    echo -e "\nNo active skills in this repo.\n"; return
  fi
  echo -e "\n${BOLD}Active skills:${RESET}\n"
  while IFS= read -r name; do
    if [[ -n "$name" ]]; then ok "$name  →  /$name"; fi
  done < "$MANIFEST_FILE"
  echo ""
}

cmd_config() {
  load_config
  load_global_config

  local subcmd="${1:-show}"
  shift 2>/dev/null || true

  case "$subcmd" in
    show)
      echo -e "\n${BOLD}Repo config${RESET} ($CONF_FILE):\n"
      if [[ -f "$CONF_FILE" ]]; then cat "$CONF_FILE"
      else echo "  (not configured — run 'skill-manager start')"; fi
      echo ""
      echo -e "${BOLD}Global config${RESET} ($GLOBAL_CONF_FILE):\n"
      if [[ -f "$GLOBAL_CONF_FILE" ]]; then cat "$GLOBAL_CONF_FILE"
      else echo "  (not configured — run 'skill-manager config global <path>')"; fi
      echo ""
      ;;
    reset)
      if [[ -f "$CONF_FILE" ]]; then
        rm "$CONF_FILE"; ok "repo config reset"
      else echo "No repo config found."; fi
      ;;
    global)
      local global_cmd="${1:-show}"
      case "$global_cmd" in
        show|"")
          if [[ -f "$GLOBAL_CONF_FILE" ]]; then
            echo -e "\n${BOLD}Global skills:${RESET} $GLOBAL_SKILLS_DIR\n"
          else echo -e "\nNo global skills configured.\n"; fi
          ;;
        remove)
          if [[ -f "$GLOBAL_CONF_FILE" ]]; then
            rm "$GLOBAL_CONF_FILE"; ok "global config removed"
          else echo "No global config found."; fi
          ;;
        *)
          local path="${global_cmd%/}"
          [[ -d "$path" ]] || die "directory not found: '$path'"
          GLOBAL_SKILLS_DIR="$path"
          save_global_config
          ;;
      esac
      ;;
    *)
      die "unknown subcommand: $subcmd (use: show | reset | global <path|remove>)"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  start)           cmd_start "$@" ;;
  resume)          cmd_resume "$@" ;;
  stop)            cmd_stop "$@" ;;
  active|status)   cmd_active "$@" ;;
  list|ls)         cmd_list "$@" ;;
  config)          cmd_config "$@" ;;
  version|-v)      echo "skill-manager $VERSION" ;;
  help|--help|-h|*)
    echo -e "
${BOLD}skill-manager $VERSION${RESET}
Activate agent skills into Claude Code for the current repo.

${BOLD}Usage:${RESET}
  skill-manager <command>

${BOLD}Session commands:${RESET}
  start             Clear previous session, select and load skills
  resume            Show active skills and add more without clearing
  stop              Remove all active skills

${BOLD}Info commands:${RESET}
  active            Show currently active skills
  list              List all available skills by source
  config            Show repo and global config
  config reset      Clear repo config
  config global <path>    Set shared global skills directory
  config global remove    Remove global config
  version           Show version

${BOLD}Skill sources:${RESET}
  ${CYAN}repo${RESET}    Skills in this repo (configured on first start)
  ${BLUE}global${RESET}  Shared skills across all repos

${BOLD}Skill status in list:${RESET}
  ${GREEN}✓${RESET}  active    ${YELLOW}⚠${RESET}  valid with warnings    ${RED}✗${RESET}  invalid — will be skipped

${BOLD}Config files:${RESET}
  .claude/.skill-manager.conf   per-repo  (keep in .gitignore)
  ~/.skill-manager.conf         global
  skills output: $CLAUDE_SKILLS_DIR/<name>/
"
    ;;
esac
