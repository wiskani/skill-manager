#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

die()  { echo -e "${RED}error: $1${RESET}" >&2; exit 1; }
ok()   { echo -e "  ${GREEN}✓${RESET} $1"; }
warn() { echo -e "  ${YELLOW}!${RESET} $1"; }

CONF_FILE=".claude/.skill-manager.conf"
MANIFEST_FILE=".claude/.skill-manifest"
COMMANDS_DIR=".claude/commands"

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

load_config() {
  SKILLS_DIR=""
  if [[ -f "$CONF_FILE" ]]; then
    source "$CONF_FILE"
  fi
}

save_config() {
  mkdir -p ".claude"
  cat > "$CONF_FILE" <<EOF
SKILLS_DIR="$SKILLS_DIR"
EOF
  ok "config saved → $CONF_FILE"
}

ensure_config() {
  load_config
  if [[ -z "$SKILLS_DIR" ]]; then
    echo -e "\n${BOLD}First time setup for this repo${RESET}"
    echo -e "${CYAN}Skills directory (relative path from repo root):${RESET} "
    read -r input
    [[ -n "$input" ]] || die "path cannot be empty"
    SKILLS_DIR="${input%/}"
    save_config
    echo ""
  fi
}

check_skills_dir() {
  [[ -d "$SKILLS_DIR" ]] || die "skills directory not found: '$SKILLS_DIR'\n       run from repo root or reset with: skill-manager config reset"
}

# ---------------------------------------------------------------------------
# Skill helpers
# ---------------------------------------------------------------------------

get_field() {
  local file="$1" field="$2"
  awk -v f="$field" '
    BEGIN { depth=0 }
    /^---/ { depth++; next }
    depth==1 && $0 ~ "^"f":" {
      sub("^"f":[[:space:]]*",""); gsub(/^["'"'"']|["'"'"']$/,""); print; exit
    }
    depth>=2 { exit }
  ' "$file"
}

strip_frontmatter() {
  awk 'BEGIN{n=0} /^---/{n++; next} n>=2{print}' "$1"
}

build_skill_list() {
  SKILL_NAMES=()
  SKILL_DIRS=()
  SKILL_DESCS=()

  for dir in "$SKILLS_DIR"/*/; do
    if [[ ! -d "$dir" ]]; then continue; fi
    local md="$dir/SKILL.md"
    if [[ ! -f "$md" ]]; then continue; fi

    local name desc
    name=$(basename "$dir")
    desc=$(get_field "$md" "description")
    desc="${desc:0:65}"

    SKILL_NAMES+=("$name")
    SKILL_DIRS+=("$dir")
    SKILL_DESCS+=("$desc")
  done
}

is_active() {
  local name="$1"
  if [[ -f "$MANIFEST_FILE" ]] && grep -qx "$name" "$MANIFEST_FILE" 2>/dev/null; then
    return 0
  fi
  return 1
}

active_mark() {
  local name="$1"
  if is_active "$name"; then
    echo "${GREEN} ✓ ${RESET}"
  else
    echo "   "
  fi
}

# ---------------------------------------------------------------------------
# Install a skill into .claude/commands/
# ---------------------------------------------------------------------------

install_skill() {
  local name="$1" dir="$2"
  local out="$COMMANDS_DIR/$name.md"

  strip_frontmatter "$dir/SKILL.md" > "$out"

  for extra in "$dir"*.md; do
    if [[ -f "$extra" && "$(basename "$extra")" != "SKILL.md" ]]; then
      { echo ""; echo "---"; cat "$extra"; } >> "$out"
    fi
  done

  if [[ -d "${dir}references" ]]; then
    for ref in "${dir}references"/*.md; do
      if [[ -f "$ref" ]]; then
        { echo ""; echo "---"; cat "$ref"; } >> "$out"
      fi
    done
  fi

  if ! grep -qx "$name" "$MANIFEST_FILE" 2>/dev/null; then
    echo "$name" >> "$MANIFEST_FILE"
  fi
  ok "$name → $out"
}

# ---------------------------------------------------------------------------
# Cleanup skills from previous session (silent)
# ---------------------------------------------------------------------------

cleanup_previous() {
  if [[ ! -f "$MANIFEST_FILE" || ! -s "$MANIFEST_FILE" ]]; then
    return
  fi
  local removed=0
  while IFS= read -r name; do
    if [[ -z "$name" ]]; then continue; fi
    local file="$COMMANDS_DIR/$name.md"
    if [[ -f "$file" ]]; then
      rm "$file"
      removed=$((removed + 1))
    fi
  done < "$MANIFEST_FILE"
  rm "$MANIFEST_FILE"
  if [[ $removed -gt 0 ]]; then
    echo -e "  ${YELLOW}↺${RESET} cleared $removed skill(s) from previous session\n"
  fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_list() {
  ensure_config
  check_skills_dir
  build_skill_list

  echo -e "\n${BOLD}Skills in $SKILLS_DIR (${#SKILL_NAMES[@]}):${RESET}\n"
  for i in "${!SKILL_NAMES[@]}"; do
    local mark
    mark=$(active_mark "${SKILL_NAMES[$i]}")
    printf "${mark}${CYAN}[%2d]${RESET} %-36s %s\n" \
      $((i+1)) "${SKILL_NAMES[$i]}" "${SKILL_DESCS[$i]}"
  done
  echo ""
}

cmd_activate() {
  ensure_config
  check_skills_dir
  cleanup_previous
  build_skill_list

  [[ ${#SKILL_NAMES[@]} -gt 0 ]] || die "no skills found in $SKILLS_DIR"

  echo -e "\n${BOLD}Available skills (${#SKILL_NAMES[@]}):${RESET}\n"
  for i in "${!SKILL_NAMES[@]}"; do
    local mark
    mark=$(active_mark "${SKILL_NAMES[$i]}")
    printf "${mark}${CYAN}[%2d]${RESET} %-36s %s\n" \
      $((i+1)) "${SKILL_NAMES[$i]}" "${SKILL_DESCS[$i]}"
  done

  echo -e "\n${YELLOW}Select (e.g: 1 3 5  |  1-4  |  all):${RESET} "
  read -r selection
  if [[ -z "$selection" ]]; then echo "Nothing selected."; exit 0; fi

  local indices=()
  if [[ "$selection" == "all" ]]; then
    for i in "${!SKILL_NAMES[@]}"; do indices+=($i); done
  else
    for token in $selection; do
      if [[ "$token" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        for ((j=${BASH_REMATCH[1]}; j<=${BASH_REMATCH[2]}; j++)); do
          indices+=($((j-1)))
        done
      elif [[ "$token" =~ ^[0-9]+$ ]]; then
        indices+=($((token-1)))
      fi
    done
  fi

  mkdir -p "$COMMANDS_DIR"
  touch "$MANIFEST_FILE"

  local count=0
  echo ""
  for idx in "${indices[@]}"; do
    if [[ $idx -lt 0 || $idx -ge ${#SKILL_NAMES[@]} ]]; then
      warn "index $((idx+1)) out of range — skipped"
      continue
    fi
    install_skill "${SKILL_NAMES[$idx]}" "${SKILL_DIRS[$idx]}"
    count=$((count + 1))
  done

  echo -e "\n${GREEN}${BOLD}$count skill(s) activated.${RESET} Use them as ${BOLD}/<name>${RESET} in Claude Code.\n"
}

cmd_active() {
  load_config
  if [[ ! -f "$MANIFEST_FILE" || ! -s "$MANIFEST_FILE" ]]; then
    echo -e "\nNo active skills in this repo.\n"
    return
  fi
  echo -e "\n${BOLD}Active skills:${RESET}\n"
  while IFS= read -r name; do
    if [[ -n "$name" ]]; then
      ok "$name  →  /$name"
    fi
  done < "$MANIFEST_FILE"
  echo ""
}

cmd_deactivate() {
  load_config
  if [[ ! -f "$MANIFEST_FILE" || ! -s "$MANIFEST_FILE" ]]; then
    echo -e "\nNo active skills to deactivate.\n"
    return
  fi

  local count=0
  echo ""
  while IFS= read -r name; do
    if [[ -z "$name" ]]; then continue; fi
    local file="$COMMANDS_DIR/$name.md"
    if [[ -f "$file" ]]; then
      rm "$file"
      echo -e "  ${RED}✗${RESET} removed $file"
      count=$((count + 1))
    fi
  done < "$MANIFEST_FILE"

  rm "$MANIFEST_FILE"
  echo -e "\n${GREEN}$count skill(s) deactivated.${RESET}\n"
}

cmd_config() {
  load_config
  local subcmd="${1:-show}"
  case "$subcmd" in
    show)
      echo -e "\n${BOLD}Config ($CONF_FILE):${RESET}\n"
      if [[ -f "$CONF_FILE" ]]; then
        cat "$CONF_FILE"
      else
        echo "  (not configured — run 'skill-manager activate' to set up)"
      fi
      echo ""
      ;;
    reset)
      if [[ -f "$CONF_FILE" ]]; then
        rm "$CONF_FILE"
        ok "config reset — next activate will ask again"
      else
        echo "No config found."
      fi
      ;;
    *)
      die "unknown subcommand: $subcmd (use: show | reset)"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  activate|on)     cmd_activate "$@" ;;
  deactivate|off)  cmd_deactivate "$@" ;;
  active|status)   cmd_active "$@" ;;
  list|ls)         cmd_list "$@" ;;
  config)          cmd_config "$@" ;;
  version|-v)      echo "skill-manager $VERSION" ;;
  help|--help|-h|*)
    echo -e "
${BOLD}skill-manager $VERSION${RESET}
Activate agent skills into Claude Code for the current repo.

${BOLD}Usage:${RESET}
  skill-manager <command>

${BOLD}Commands:${RESET}
  activate         Interactive skill selection (asks skills path on first run)
  deactivate       Remove skills activated in this repo
  active           Show currently active skills
  list             List all available skills with status
  config [show]    Show current repo config
  config reset     Clear config (re-asks on next activate)
  version          Show version

${BOLD}First run in a new repo:${RESET}
  cd your-project
  skill-manager activate
  → Skills directory (relative path from repo root): .agents/skills

${BOLD}Config saved to:${RESET}  .claude/.skill-manager.conf
${BOLD}Skills output:${RESET}    .claude/commands/<name>.md
${BOLD}Both paths are local-only — add .claude/ to .gitignore${RESET}
"
    ;;
esac
